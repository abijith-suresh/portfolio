---
import Breadcrumb from "@/components/Breadcrumb.astro";
import TOCSidebar from "@/components/TOCSidebar.astro";
import type { BreadcrumbItem } from "@/lib/types";
import type { MarkdownHeading } from "astro";

interface MetaItem {
  type: "date" | "text";
  value: string;
  datetime?: string;
}

interface Props {
  /** Breadcrumb trail */
  breadcrumbs: BreadcrumbItem[];
  /** Page title */
  title: string;
  /** Description paragraph */
  description?: string;
  /** Meta items (date, reading time, etc.) */
  meta?: MetaItem[];
  /** Hero image URL */
  heroImage?: string;
  /** TOC headings */
  tocHeadings?: MarkdownHeading[];
  /** Additional elements in the header (buttons, etc.) */
  headerExtras?: boolean;
  class?: string;
}

const {
  breadcrumbs,
  title,
  description,
  meta,
  heroImage,
  tocHeadings = [],
  headerExtras = false,
  class: className,
} = Astro.props;
---

<section
  class:list={[
    "grid grid-cols-[minmax(0px,1fr)_min(768px,100%)_minmax(0px,1fr)] gap-y-6 pb-16 page-enter",
    className,
  ]}
>
  <!-- Breadcrumb -->
  <div class="col-start-2 px-6 md:px-8 pt-8 page-enter page-enter-delay-1">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Header -->
  <header class="col-start-2 flex flex-col gap-y-5 px-6 md:px-8 pt-4 page-enter page-enter-delay-2">
    <h1 class="text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight leading-tight">
      {title}
    </h1>

    {
      meta && meta.length > 0 && (
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
          {meta.map((item, index) => (
            <>
              {item.type === "date" ? (
                <time class="eyebrow" datetime={item.datetime}>
                  {item.value}
                </time>
              ) : (
                <span class="eyebrow">{item.value}</span>
              )}
              {index < meta.length - 1 && <span style="color: var(--color-muted);">&middot;</span>}
            </>
          ))}
        </div>
      )
    }

    {
      description && (
        <p class="text-lg leading-relaxed max-w-2xl" style="color: var(--color-muted-foreground);">
          {description}
        </p>
      )
    }

    <!-- Slot for header extras: buttons, tag lists, etc. -->
    {headerExtras && <slot name="header-extras" />}
  </header>

  <!-- Hero Image -->
  {
    heroImage && (
      <div class="col-start-2 px-6 md:px-8 page-enter page-enter-delay-2">
        <img src={heroImage} alt={title} class="w-full object-cover" />
      </div>
    )
  }

  <!-- TOC Sidebar (desktop) -->
  {tocHeadings.length > 0 && <TOCSidebar headings={tocHeadings} />}

  <!-- Prose Content -->
  <article class="prose col-start-2 max-w-none px-6 md:px-8 page-enter page-enter-delay-2">
    <slot />
  </article>

  <!-- After-content slot (related posts, etc.) -->
  <div class="col-start-2 px-6 md:px-8 page-enter page-enter-delay-3">
    <slot name="after-content" />
  </div>
</section>

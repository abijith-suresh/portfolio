---
import { NAV_LINKS } from "@/consts";
import Link from "@/components/Link.astro";
import Container from "@/components/ui/Container.astro";
import { Icon } from "astro-icon/components";

const currentPath = Astro.url.pathname;
---

<Container class="flex items-center justify-between py-4 md:py-5">
  <a
    href="/"
    class="text-xl font-bold tracking-tight"
    style="color: var(--color-accent);"
    data-astro-prefetch="tap"
  >
    AS
  </a>

  <!-- Desktop nav -->
  <div class="hidden md:flex items-center gap-6">
    <nav class="flex items-center gap-5">
      {
        NAV_LINKS.map((link) => {
          const isActive = currentPath.startsWith(link.href);
          return (
            <Link
              href={link.href}
              class:list={["nav-link", isActive && "active"]}
              prefetch="viewport"
            >
              {link.label}
            </Link>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-1">
      <button
        onclick="window.openSearchModal?.()"
        aria-label="Open search"
        class="icon-button p-2"
        title="Search"
      >
        <Icon name="fa6-solid:magnifying-glass" class="w-4 h-4" />
      </button>
    </div>
  </div>

  <!-- Mobile controls -->
  <div class="flex md:hidden items-center gap-1">
    <button
      onclick="window.openSearchModal?.()"
      aria-label="Open search"
      class="icon-button p-2"
      title="Search"
    >
      <Icon name="fa6-solid:magnifying-glass" class="w-4 h-4" />
    </button>

    <button
      id="mobile-nav-open"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav-drawer"
      class="icon-button p-2"
    >
      <Icon name="fa6-solid:bars" class="w-4 h-4" />
    </button>
  </div>
</Container>

<!-- Mobile nav overlay — opacity-animated backdrop -->
<div
  id="mobile-nav-overlay"
  class="fixed inset-0 z-50 pointer-events-none"
  style="background: rgba(0, 0, 0, 0.65); opacity: 0; transition: opacity 200ms ease;"
  aria-hidden="true"
>
  <!-- Drawer — slides in from the right -->
  <nav
    id="mobile-nav-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    class="absolute right-0 top-0 bottom-0 w-64 flex flex-col pointer-events-auto"
    style="background: var(--color-base); border-left: 1px solid var(--color-border); transform: translateX(100%); transition: transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);"
  >
    <!-- Drawer header -->
    <div
      class="flex items-center justify-between px-6 py-4"
      style="border-bottom: 1px solid var(--color-border);"
    >
      <span class="eyebrow">Menu</span>
      <button id="mobile-nav-close" aria-label="Close navigation menu" class="icon-button p-2">
        <Icon name="fa6-solid:xmark" class="w-4 h-4" />
      </button>
    </div>

    <!-- Nav links -->
    <ul class="flex flex-col mt-2">
      {
        NAV_LINKS.map((link) => {
          const isActive = currentPath.startsWith(link.href);
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "flex items-center justify-between px-6 py-4 nav-link text-base",
                  "border-b border-[var(--color-border)]",
                  isActive && "active",
                ]}
              >
                {link.label}
                <Icon name="fa6-solid:arrow-right" class="w-3 h-3 opacity-30" />
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</div>

<style>
  /* Honour prefers-reduced-motion for the nav drawer animations */
  @media (prefers-reduced-motion: reduce) {
    #mobile-nav-overlay,
    #mobile-nav-drawer {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  function initMobileNav() {
    const overlay = document.getElementById("mobile-nav-overlay") as HTMLElement | null;
    const drawer = document.getElementById("mobile-nav-drawer") as HTMLElement | null;
    const openBtn = document.getElementById("mobile-nav-open");
    const closeBtn = document.getElementById("mobile-nav-close");

    if (!overlay || !drawer || !openBtn || !closeBtn) return;

    function openMenu() {
      overlay!.style.opacity = "1";
      overlay!.style.pointerEvents = "auto";
      drawer!.style.transform = "translateX(0)";
      overlay!.setAttribute("aria-hidden", "false");
      openBtn!.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      closeBtn!.focus();
    }

    function closeMenu() {
      overlay!.style.opacity = "0";
      overlay!.style.pointerEvents = "none";
      drawer!.style.transform = "translateX(100%)";
      overlay!.setAttribute("aria-hidden", "true");
      openBtn!.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      openBtn!.focus();
    }

    openBtn.addEventListener("click", openMenu);
    closeBtn.addEventListener("click", closeMenu);

    // Close on overlay backdrop click
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeMenu();
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay!.getAttribute("aria-hidden") === "false") {
        closeMenu();
      }
    });
  }

  initMobileNav();
  document.addEventListener("astro:after-swap", initMobileNav);
</script>

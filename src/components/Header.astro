---
import { NAV_LINKS } from "@/consts";
import Link from "@/components/Link.astro";
import ThemePicker from "@/components/ThemePicker.astro";
import Container from "@/components/ui/Container.astro";
import { Icon } from "astro-icon/components";

const currentPath = Astro.url.pathname;
---

<Container class="flex items-center justify-between py-4 md:py-5">
  <a
    href="/"
    class="text-xl font-bold tracking-tight"
    style="color: var(--color-accent);"
    data-astro-prefetch="tap"
  >
    AS
  </a>

  <div class="flex items-center gap-6">
    <nav class="flex items-center gap-5">
      {
        NAV_LINKS.map((link) => {
          const isActive = currentPath.startsWith(link.href);
          return (
            <Link
              href={link.href}
              class:list={["nav-link", isActive && "active"]}
              prefetch="viewport"
            >
              {link.label}
            </Link>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-1">
      <button
        onclick="window.openSearchModal?.()"
        aria-label="Open search"
        class="icon-button p-2"
        title="Search"
      >
        <Icon name="fa6-solid:magnifying-glass" class="w-4 h-4" />
      </button>

      <ThemePicker />
    </div>
  </div>
</Container>

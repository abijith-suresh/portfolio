---
import Link from "@/components/Link.astro";
import { getTagHref } from "@/lib/tags";
import { cn } from "@/lib/utils";

interface Props {
  tags: string[];
  class?: string;
  linkClass?: string;
}

const { tags, class: className, linkClass } = Astro.props;
---

{
  tags.length > 0 && (
    <div class:list={cn("flex flex-wrap gap-2", className)}>
      {tags.map((tag) => (
        <Link
          href={getTagHref(tag)}
          class:list={cn("text-xs px-3 py-1.5 rounded-md font-medium transition-colors", linkClass)}
          style="background: var(--color-warm-muted); color: var(--color-warm);"
          prefetch="viewport"
        >
          {tag}
        </Link>
      ))}
    </div>
  )
}

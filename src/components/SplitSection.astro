---
interface Props {
  /** Content for the left (25%) column — e.g. year, letter, section heading */
  label: string;
  /** Optional sub-label below the main label */
  sublabel?: string;
  class?: string;
}

const { label, sublabel, class: className } = Astro.props;
---

<div class:list={["grid grid-cols-1 md:grid-cols-[25%_1fr] gap-y-2 gap-x-8", className]}>
  <div class="flex flex-col">
    <span class="split-label">
      {label}
    </span>
    {
      sublabel && (
        <span class="text-sm mt-1" style="color: var(--color-muted-foreground);">
          {sublabel}
        </span>
      )
    }
  </div>
  <div class="md:border-l md:border-[var(--color-border)] md:pl-8">
    <slot />
  </div>
</div>

---
import Breadcrumb from "@/components/Breadcrumb.astro";
import Container from "@/components/ui/Container.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import type { BreadcrumbItem } from "@/lib/types";

interface Props {
  /** Breadcrumb trail items */
  breadcrumbs: BreadcrumbItem[];
  /** Small uppercase label above the title */
  eyebrow?: string;
  /** Page title */
  title: string;
  /** Subtitle / description below the title */
  subtitle?: string;
  /** Additional CSS class for the outer wrapper */
  class?: string;
}

const { breadcrumbs, eyebrow, title, subtitle, class: className } = Astro.props;
---

<div class:list={["w-full mx-auto flex grow flex-col gap-y-10 pb-16 page-enter", className]}>
  <Container class="pt-8 flex flex-col gap-y-8">
    <div class="page-enter page-enter-delay-1">
      <Breadcrumb items={breadcrumbs} />
    </div>
    <PageHeader
      eyebrow={eyebrow}
      title={title}
      subtitle={subtitle}
      class="page-enter page-enter-delay-2"
    />
  </Container>

  <slot />
</div>

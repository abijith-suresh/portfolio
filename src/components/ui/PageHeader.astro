---
interface Props {
  /** Small uppercase label above the title */
  eyebrow?: string;
  /** Page title */
  title: string;
  /** Subtitle / description below the title */
  subtitle?: string;
  /** Additional CSS class */
  class?: string;
}

const { eyebrow, title, subtitle, class: className } = Astro.props;
---

<div class:list={["flex flex-col gap-y-2", className]}>
  {
    eyebrow && (
      <>
        <span class="eyebrow">{eyebrow}</span>
        <div class="w-12 border-t-2 border-[var(--color-accent)]" />
      </>
    )
  }
  <h1 class="text-[clamp(1.875rem,4vw,3rem)] font-bold tracking-tight">{title}</h1>
  {subtitle && <p style="color: var(--color-muted-foreground);">{subtitle}</p>}
</div>

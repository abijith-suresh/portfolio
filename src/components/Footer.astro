---
import Link from "@/components/Link.astro";
import { SITE, SOCIAL_LINKS } from "@/consts";

const currentYear = new Date().getFullYear();
---

<footer class="mt-auto">
  <div class="mx-auto max-w-[1200px] px-6 md:px-8 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <Link href={SOCIAL_LINKS.github} external class="footer-link">
          GitHub
          <span class="footer-link-arrow">↗</span>
        </Link>
        <Link href={SOCIAL_LINKS.x} external class="footer-link">
          X
          <span class="footer-link-arrow">↗</span>
        </Link>
        <Link href={SOCIAL_LINKS.linkedin} external class="footer-link">
          LinkedIn
          <span class="footer-link-arrow">↗</span>
        </Link>
        <Link href={SOCIAL_LINKS.bluesky} external class="footer-link">
          Bluesky
          <span class="footer-link-arrow">↗</span>
        </Link>
        <Link href="/rss.xml" class="footer-link">
          RSS
          <span class="footer-link-arrow">→</span>
        </Link>
      </div>

      <p class="eyebrow">
        &copy; {currentYear}
        {SITE.author}
      </p>
    </div>
  </div>
</footer>

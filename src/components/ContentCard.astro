---
import Link from "@/components/Link.astro";
import Tag from "@/components/ui/Tag.astro";
import { cn } from "@/lib/utils";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  tags: string[];
  href: string;
  meta?: string;
  class?: string;
}

const { title, description, tags, href, meta, class: className } = Astro.props;
---

<article class:list={cn("group card-hover", className)}>
  <Link href={href} class="block p-6" prefetch="hover">
    <div class="flex flex-col gap-3">
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-lg font-semibold leading-snug">
          {title}
        </h3>
        <Icon
          name="fa6-solid:arrow-right"
          class="w-4 h-4 shrink-0 mt-1.5 opacity-0 group-hover:opacity-100 transition-opacity"
          style="color: var(--color-card-hover-text);"
        />
      </div>
      {meta && <p class="eyebrow">{meta}</p>}
      <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--color-muted-foreground);">
        {description}
      </p>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-1">
            {tags.map((tag: string) => (
              <Tag label={tag} />
            ))}
          </div>
        )
      }
    </div>
  </Link>
</article>

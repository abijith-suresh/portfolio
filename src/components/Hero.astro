---
import { SITE } from "@/consts";
import Container from "@/components/ui/Container.astro";
---

<section class="pt-24 pb-20 md:pt-36 md:pb-28">
  <Container>
    <div class="flex flex-col gap-8">
      <div class="page-enter flex flex-col gap-4">
        <span class="eyebrow page-enter">{SITE.role}</span>
        <div class="w-12 border-t-2 border-[var(--color-accent)]"></div>
        <h1 class="text-[clamp(3.5rem,8vw,6rem)] font-bold tracking-tight leading-[1.05]">
          {SITE.greeting}
        </h1>
      </div>

      <p
        class="text-lg leading-relaxed max-w-[75ch] page-enter page-enter-delay-1"
        style="color: var(--color-muted-foreground);"
      >
        {
          SITE.heroIntro.split("\n").map((line: string) => (
            <>
              {line}
              <br />
            </>
          ))
        }
      </p>
    </div>
  </Container>
</section>

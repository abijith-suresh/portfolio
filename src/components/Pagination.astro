---
import Link from "@/components/Link.astro";
import { cn } from "@/lib/utils";
import { Icon } from "astro-icon/components";

interface Props {
  currentPage: number;
  totalPages: number;
  prevUrl: string | null;
  nextUrl: string | null;
  hasPrev: boolean;
  hasNext: boolean;
  ariaLabel?: string;
}

const {
  currentPage,
  totalPages,
  prevUrl,
  nextUrl,
  hasPrev,
  hasNext,
  ariaLabel = "Pagination",
} = Astro.props;
---

{
  totalPages > 1 && (
    <nav aria-label={ariaLabel} class="flex items-center justify-between pt-10">
      <div class="flex-1">
        {hasPrev && prevUrl && (
          <Link href={prevUrl} class:list={cn("btn btn-secondary")} data-astro-prefetch="viewport">
            <Icon name="fa6-solid:chevron-left" class="w-3.5 h-3.5" />
            Previous
          </Link>
        )}
      </div>

      <div class="flex items-center gap-2 eyebrow">
        <span>
          {currentPage} / {totalPages}
        </span>
      </div>

      <div class="flex-1 flex justify-end">
        {hasNext && nextUrl && (
          <Link href={nextUrl} class:list={cn("btn btn-secondary")} data-astro-prefetch="viewport">
            Next
            <Icon name="fa6-solid:chevron-right" class="w-3.5 h-3.5" />
          </Link>
        )}
      </div>
    </nav>
  )
}

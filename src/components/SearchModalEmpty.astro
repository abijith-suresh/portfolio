---
import { Icon } from "astro-icon/components";
---

<div id="search-empty" class="hidden flex-col items-center justify-center py-12 px-4 text-center">
  <Icon name="fa6-solid:file-lines" class="w-10 h-10 mb-4" style="color: var(--color-muted);" />
  <h3 class="text-lg font-semibold mb-2">No results found</h3>
  <p class="text-sm max-w-sm mb-6" style="color: var(--color-muted-foreground);">
    We couldn't find any matches for your search. Try different keywords or check your spelling.
  </p>
  <div class="flex flex-wrap gap-2 justify-center">
    <a href="/blog" class="btn btn-primary"> Browse Blog </a>
    <a href="/projects" class="btn btn-secondary"> Browse Projects </a>
  </div>
</div>

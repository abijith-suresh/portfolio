---
import ReadingProgress from "@/components/ReadingProgress.astro";
import RelatedPosts from "@/components/RelatedPosts.astro";
import ContentDetailPage from "@/components/ContentDetailPage.astro";
import TagList from "@/components/TagList.astro";
import TOCHeader from "@/components/TOCHeader.astro";
import { SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import { getRelatedPosts } from "@/lib/recommendations";
import { filterTocHeadings } from "@/lib/toc";
import { calculateReadingTime, formatBlogDate, formatReadingTime } from "@/lib/utils";
import { type CollectionEntry, getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", (post) => !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, tags, publishDate, heroImage } = post.data;
const { Content, headings } = await render(post);
const formattedDate = formatBlogDate(publishDate);
const readingTime = calculateReadingTime(post.body ?? "");

const tocHeadings = filterTocHeadings(headings);

const relatedPosts = await getRelatedPosts(post.id, 3);
---

<Layout
  title={`${title} - Blog - ${SITE.title}`}
  description={description}
  type="article"
  article={{
    publishedTime: publishDate,
    authors: [SITE.author],
    tags: tags,
  }}
  jsonLd={{
    type: "article",
    article: {
      headline: title,
      description: description,
      datePublished: publishDate,
      keywords: tags,
    },
  }}
>
  <ReadingProgress />
  {tocHeadings.length > 0 && <TOCHeader slot="table-of-contents" headings={tocHeadings} />}

  <ContentDetailPage
    breadcrumbs={[
      { label: "Home", href: "/", icon: "fa6-solid:house" },
      { label: "Blog", href: "/blog", icon: "fa6-solid:book-open" },
      { label: title, icon: "fa6-solid:file-lines" },
    ]}
    title={title}
    description={description}
    meta={[
      { type: "date", value: formattedDate, datetime: publishDate.toISOString() },
      { type: "text", value: formatReadingTime(readingTime) },
    ]}
    heroImage={heroImage}
    tocHeadings={tocHeadings}
    headerExtras
  >
    <TagList slot="header-extras" tags={tags} />
    <Content />
    <RelatedPosts slot="after-content" posts={relatedPosts} />
  </ContentDetailPage>
</Layout>

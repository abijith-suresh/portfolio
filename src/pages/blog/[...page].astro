---
import BlogCard from "@/components/BlogCard.astro";
import PaginatedListLayout from "@/components/PaginatedListLayout.astro";
import SplitSection from "@/components/SplitSection.astro";
import Container from "@/components/ui/Container.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import PageShell from "@/components/ui/PageShell.astro";
import { SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import { getAllBlogPosts } from "@/lib/blog";
import { groupByYear } from "@/lib/group-by-year";
import { buildPaginationUrls, generatePaginatedPaths } from "@/lib/paginated-routes";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const allPosts = await getAllBlogPosts();
  return generatePaginatedPaths(allPosts, SITE.postsPerPage);
}

interface Props {
  items: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
  hasNext: boolean;
  hasPrev: boolean;
}

const { items: posts, currentPage, totalPages, hasNext, hasPrev } = Astro.props;

const { prevUrl, nextUrl } = buildPaginationUrls("/blog", currentPage, hasPrev, hasNext);
const postsByYear = groupByYear(posts, (post) => post.data.publishDate);
---

<Layout
  title={`Blog${currentPage > 1 ? ` - Page ${currentPage}` : ""} - ${SITE.title}`}
  description="Articles, tutorials, and thoughts on web development, design, and technology."
  jsonLd={{ type: "website" }}
>
  <PageShell
    breadcrumbs={[
      { label: "Home", href: "/", icon: "fa6-solid:house" },
      { label: "Blog", icon: "fa6-solid:book-open" },
    ]}
    eyebrow="Writing"
    title="Blog"
    subtitle="Notes, write-ups, and the occasional opinion"
  >
    {
      posts.length > 0 ? (
        <Container>
          <PaginatedListLayout
            currentPage={currentPage}
            totalPages={totalPages}
            prevUrl={prevUrl}
            nextUrl={nextUrl}
            hasPrev={hasPrev}
            hasNext={hasNext}
            ariaLabel="Blog pagination"
          >
            <div slot="items" class="flex flex-col gap-8">
              {postsByYear.map(({ year, items: yearPosts }) => (
                <SplitSection label={String(year)}>
                  <div class="flex flex-col gap-3">
                    {yearPosts.map((post) => (
                      <BlogCard post={post} />
                    ))}
                  </div>
                </SplitSection>
              ))}
            </div>
          </PaginatedListLayout>
        </Container>
      ) : (
        <EmptyState message="No blog posts to display yet." />
      )
    }
  </PageShell>
</Layout>

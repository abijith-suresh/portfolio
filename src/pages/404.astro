---
import Link from "@/components/Link.astro";
import Container from "@/components/ui/Container.astro";
import { SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout
  title={`404 - Page Not Found | ${SITE.title}`}
  description="The page you're looking for doesn't exist."
  noindex={true}
  jsonLd={{ type: "website" }}
>
  <div class="w-full mx-auto flex grow flex-col page-enter">
    <Container class="flex flex-col items-center justify-center gap-y-8 py-28 page-enter">
      <div
        class="text-[8rem] font-bold select-none leading-none"
        style="color: var(--color-accent); opacity: 0.3;"
        aria-hidden="true"
      >
        404
      </div>

      <div class="flex flex-col items-center gap-y-3 text-center">
        <h1 class="text-3xl font-bold tracking-tight">Page Not Found</h1>
        <p class="text-lg max-w-md" style="color: var(--color-muted-foreground);">
          The page you're looking for doesn't exist or has been moved.
        </p>
      </div>

      <div class="pt-4">
        <Link href="/" class="btn btn-primary" prefetch="viewport">
          <Icon name="fa6-solid:arrow-left" class="w-3.5 h-3.5" />
          Back to Home
        </Link>
      </div>
    </Container>
  </div>
</Layout>

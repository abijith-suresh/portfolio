---
import Link from "@/components/Link.astro";
import SplitSection from "@/components/SplitSection.astro";
import Container from "@/components/ui/Container.astro";
import PageShell from "@/components/ui/PageShell.astro";
import { SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import { getAllContentTagCounts } from "@/lib/content-tags";
import { groupByFirstLetter } from "@/lib/group-by-letter";

const tags = await getAllContentTagCounts();
const tagsByLetter = groupByFirstLetter(tags, (t) => t.label);
---

<Layout
  title={`All Tags - ${SITE.title}`}
  description="Browse all blog posts and projects by topic. Explore tags and discover content that interests you."
  jsonLd={{ type: "website" }}
>
  <PageShell
    breadcrumbs={[
      { label: "Home", href: "/", icon: "home" },
      { label: "Tags", icon: "tags" },
    ]}
    eyebrow="Browse"
    title="All Tags"
    subtitle="Browse posts and projects by topic"
  >
    {
      tagsByLetter.length > 0 ? (
        <Container class="flex flex-col gap-8">
          {tagsByLetter.map(({ letter, items }) => (
            <SplitSection label={letter}>
              <div class="flex flex-wrap gap-2">
                {items.map(({ slug, label, totalCount }) => (
                  <Link href={`/tags/${slug}`} class="tag-link" prefetch="viewport">
                    <span class="tag-link-label">{label}</span>
                    <span class="tag-link-count">{totalCount}</span>
                  </Link>
                ))}
              </div>
            </SplitSection>
          ))}
        </Container>
      ) : (
        <p class="text-center py-16" style="color: var(--color-muted-foreground);">
          No tags found.
        </p>
      )
    }
  </PageShell>
</Layout>

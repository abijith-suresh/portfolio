---
import Breadcrumb from "@/components/Breadcrumb.astro";
import SplitSection from "@/components/SplitSection.astro";
import { AUTHOR, SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title={`About - ${SITE.title}`}
  description={`Learn more about ${AUTHOR.name} - ${AUTHOR.tagline}`}
  type="profile"
  jsonLd={{ type: "person" }}
>
  <div class="w-full mx-auto flex grow flex-col gap-y-16 pb-16 page-enter">
    <div class="mx-auto w-full max-w-[1200px] px-6 md:px-8 pt-8">
      <div class="page-enter page-enter-delay-1">
        <Breadcrumb
          items={[
            { label: "Home", href: "/", icon: "home" },
            { label: "About", icon: "about" },
          ]}
        />
      </div>
    </div>

    <!-- Identity header — 25/75 split: avatar left, name right -->
    <header class="mx-auto w-full max-w-[1200px] px-6 md:px-8 page-enter page-enter-delay-1">
      <SplitSection label="About">
        <div class="flex items-center gap-8">
          <img
            src={AUTHOR.avatar}
            alt={AUTHOR.name}
            class="w-20 h-20 sm:w-28 sm:h-28 rounded-full object-cover flex-shrink-0"
          />
          <div>
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-[1.1]">
              {AUTHOR.fullName}
            </h1>
            <p class="mt-2" style="color: var(--color-muted-foreground);">{AUTHOR.tagline}</p>
          </div>
        </div>
      </SplitSection>
    </header>

    <!-- Narrative sections — 25/75 split -->
    <div class="mx-auto w-full max-w-[1200px] px-6 md:px-8 flex flex-col gap-12">
      <!-- Section: What I do -->
      <section class="page-enter page-enter-delay-2">
        <SplitSection label="The day job" sublabel="What I do">
          <p class="leading-relaxed max-w-[65ch]" style="color: var(--color-muted-foreground);">
            {AUTHOR.aboutWhatIDo}
          </p>
        </SplitSection>
      </section>

      <!-- Section: How I got here -->
      <section class="page-enter page-enter-delay-2">
        <SplitSection label="The path" sublabel="How I got here">
          <p class="leading-relaxed max-w-[65ch]" style="color: var(--color-muted-foreground);">
            {AUTHOR.aboutHowIGotHere}
          </p>
        </SplitSection>
      </section>

      <!-- Section: This site -->
      <section class="page-enter page-enter-delay-3">
        <SplitSection label="Why it exists" sublabel="This site">
          <p class="leading-relaxed max-w-[65ch]" style="color: var(--color-muted-foreground);">
            {AUTHOR.aboutThisSite}
          </p>
        </SplitSection>
      </section>

      <!-- Section: Away from the keyboard -->
      <section class="page-enter page-enter-delay-3">
        <SplitSection label="When I'm not coding" sublabel="Away from the keyboard">
          <div class="flex flex-wrap gap-2">
            {AUTHOR.interests.map((interest) => <span class="tag-pill">{interest}</span>)}
          </div>
        </SplitSection>
      </section>
    </div>
  </div>
</Layout>
